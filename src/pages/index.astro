---
import "../styles/concepts.css";

const services = [
  {
    number: "01",
    label: "Evaluate",
    title: "Understand the body before changing the plan.",
    text: "Movement, strength, posture, balance, history, and goals become the baseline.",
  },
  {
    number: "02",
    label: "Train",
    title: "Build strength with better decisions.",
    text: "Personal training guided by safer mechanics, smarter loading, and clearer progressions.",
  },
  {
    number: "03",
    label: "Coach",
    title: "Keep momentum beyond the room.",
    text: "Online support gives structure, accountability, and expert feedback from anywhere.",
  },
];

const foldCards = [
  {
    title: "Personalized training",
    text: "Plans shaped around goals, history, and current fitness level.",
  },
  {
    title: "Clinical expertise",
    text: "Doctor-led evaluation with practical coaching for safer progress.",
  },
  {
    title: "Comprehensive approach",
    text: "Fitness, wellness, recovery, and accountability in one plan.",
  },
];

const basePath = import.meta.env.BASE_URL.endsWith("/") ? import.meta.env.BASE_URL : `${import.meta.env.BASE_URL}/`;
const withBase = (path = "") => `${basePath}${path.replace(/^\//, "")}`;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <meta
      name="description"
      content="Valencia Health & Wellness provides doctor-led fitness, health evaluations, personal training, and online coaching in Coconut Creek and virtually."
    />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Fraunces:opsz,wght@9..144,500;9..144,650;9..144,800&family=Manrope:wght@500;650;750;850&display=swap"
      rel="stylesheet"
    />
    <link rel="icon" type="image/png" href={withBase("/assets/brand/valencia-health-wellness-icon.png")} />
    <title>Valencia Health & Wellness, LLC</title>
  </head>
  <body class="concept-page v4">
    <main>
      <div class="v4-topbar" aria-label="Contact information">
        <div>
          <a href="tel:19542996536">954-299-6536</a>
          <a href="tel:15613425258">561-342-5258</a>
        </div>
        <a href="mailto:info@vhwpt.com">info@vhwpt.com</a>
      </div>

      <nav class="v4-nav" aria-label="Primary">
        <a class="v4-brand" href={withBase()}>
          <img src={withBase("/assets/brand/valencia-health-wellness-logo-header.png")} alt="" />
          <span>
            <strong>Valencia Health & Wellness, LLC</strong>
            <small>Dr. Bruce Valencia, DPT</small>
          </span>
        </a>
        <div class="v4-nav-links">
          <a href={withBase()}>Home</a>
          <a href="#services">Services</a>
          <a href="#doctor">About</a>
          <a href="#contact">Contact</a>
        </div>
        <a class="v4-appointment" href="#contact">Book appointment</a>
      </nav>

      <header class="v4-fold">
        <section class="v4-hero" aria-labelledby="hero-title">
          <div class="v4-hero-copy">
            <p class="concept-eyebrow">Coconut Creek and virtual wellness coaching</p>
            <h1 id="hero-title">Valencia Health & Wellness, LLC</h1>
            <p>
              Personalized fitness, health evaluations, and wellness coaching led by Dr. Bruce Valencia.
            </p>
            <div class="v4-fold-cards" aria-label="Highlights">
              {foldCards.map((card) => (
                <article>
                  <span aria-hidden="true"></span>
                  <h2>{card.title}</h2>
                  <p>{card.text}</p>
                </article>
              ))}
            </div>
            <a class="concept-button primary" href="#contact">Book appointment</a>
          </div>
          <div class="v4-portrait" aria-label="Dr. Bruce Valencia">
            <img src={withBase("/assets/brand/bruce-headshot.webp")} alt="Dr. Bruce Valencia" />
          </div>
        </section>
      </header>

      <section class="tone-strip" aria-label="Brand focus">
        <span>Calm Care</span>
        <p>Soft, reassuring, trustworthy care with doctor-led fitness and wellness strategy.</p>
        <a href="#contact">Start</a>
      </section>

      <section id="services" class="concept-services">
        <div class="concept-section-heading">
          <p class="concept-eyebrow">Services</p>
          <h2>Gentle pacing, high trust, and approachable expertise.</h2>
        </div>
        <div class="concept-service-list">
          {services.map((service) => (
            <article>
              <span>{service.number}</span>
              <p>{service.label}</p>
              <h3>{service.title}</h3>
              <p>{service.text}</p>
            </article>
          ))}
        </div>
      </section>

      <section id="doctor" class="concept-doctor">
        <img src={withBase("/assets/brand/bruce-headshot.webp")} alt="Dr. Bruce Valencia" />
        <div>
          <p class="concept-eyebrow">Dr. Bruce Valencia</p>
          <h2>Clinical care can feel calm, direct, and deeply human.</h2>
          <p>
            Doctor of Physical Therapy and Certified Lymphedema Therapist, blending evaluation, training, and wellness strategy into practical coaching.
          </p>
        </div>
      </section>

      <section id="contact" class="concept-contact">
        <img src={withBase("/assets/brand/valencia-health-wellness-logo-display.png")} alt="Valencia Health & Wellness logo" />
        <div>
          <p class="concept-eyebrow">Private consultation</p>
          <h2>Start with a clearer picture of what your body needs next.</h2>
          <a class="concept-button primary" href="tel:19542996536">Call 954-299-6536</a>
        </div>
      </section>
    </main>
  </body>
</html>
