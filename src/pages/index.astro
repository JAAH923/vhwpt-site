---
import "../styles/concepts.css";

const benefits = [
  {
    title: "Personalized training",
    text: "Customized workout plans tailored to individual goals and fitness levels.",
  },
  {
    title: "Expert coaches",
    text: "Certified trainers with specialized expertise in various fitness and wellness areas.",
  },
  {
    title: "Community focus",
    text: "Creating a supportive and motivating environment for all clients.",
  },
  {
    title: "Flexible scheduling",
    text: "Convenient options for in-person and virtual training sessions.",
  },
  {
    title: "Comprehensive approach",
    text: "Integrating fitness, nutrition, and wellness for holistic health.",
  },
];

const programs = [
  {
    title: "Senior fitness program",
    text: "Tailored exercise routines to improve mobility, balance, and strength for older adults.",
  },
  {
    title: "Weight management and nutritional counseling",
    text: "Personalized plans for weight loss, healthy eating habits, and sustainable wellness.",
  },
  {
    title: "Youth fitness and sports training",
    text: "Helping young athletes improve performance, strength, and agility.",
  },
  {
    title: "Rehabilitation and injury prevention",
    text: "Recovery programs for individuals recovering from injuries or surgeries.",
  },
  {
    title: "Corporate wellness programs",
    text: "Health and fitness programming designed to support stronger, more resilient teams.",
  },
  {
    title: "Pre and postnatal fitness",
    text: "Safe, supportive movement plans for pregnancy, postpartum recovery, and changing bodies.",
  },
  {
    title: "Holistic wellness programs",
    text: "Wellness strategies that bring together fitness, recovery, stress management, and long-term health.",
  },
];

const basePath = import.meta.env.BASE_URL.endsWith("/") ? import.meta.env.BASE_URL : `${import.meta.env.BASE_URL}/`;
const withBase = (path = "") => `${basePath}${path.replace(/^\//, "")}`;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <meta
      name="description"
      content="Valencia Health & Wellness provides doctor-led fitness, health evaluations, personal training, and online coaching in Coconut Creek and virtually."
    />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Fraunces:opsz,wght@9..144,500;9..144,650;9..144,800&family=Manrope:wght@500;650;750;850&display=swap"
      rel="stylesheet"
    />
    <link rel="icon" type="image/png" href={withBase("/assets/brand/valencia-health-wellness-icon.png")} />
    <title>Valencia Health & Wellness, LLC</title>
  </head>
  <body class="concept-page v4">
    <main>
      <nav class="v4-nav" aria-label="Primary">
        <a class="v4-brand" href={withBase()}>
          <img src={withBase("/assets/brand/valencia-health-wellness-logo-header.png")} alt="" />
          <span>
            <strong>Valencia Health & Wellness, LLC</strong>
            <small>Dr. Bruce Valencia, DPT</small>
          </span>
        </a>
        <input class="v4-menu-toggle" type="checkbox" id="primary-menu" aria-label="Toggle navigation menu" />
        <label class="v4-menu-button" for="primary-menu" aria-label="Open navigation menu">
          <span></span>
          <span></span>
          <span></span>
        </label>
        <div class="v4-mobile-menu">
          <div class="v4-nav-links">
            <a href={withBase()}>Home</a>
            <a href="#services">Services</a>
            <a href="#doctor">About</a>
            <a href="#contact">Contact</a>
          </div>
          <a class="v4-appointment" href="#contact">Book appointment</a>
        </div>
      </nav>

      <header class="v4-editorial-fold">
        <section class="v4-editorial-hero" aria-labelledby="hero-title">
          <div class="v4-editorial-portrait" aria-label="Dr. Bruce Valencia">
            <img src={withBase("/assets/brand/bruce-headshot.webp")} alt="Dr. Bruce Valencia" />
          </div>
          <div class="v4-editorial-copy">
            <p class="concept-eyebrow">Dr. Bruce Valencia</p>
            <h1 id="hero-title">Clinical care can feel calm, direct, and deeply human.</h1>
            <p>
              Doctor of Physical Therapy and Certified Lymphedema Therapist, blending evaluation, training, and wellness strategy into practical coaching.
            </p>
            <div class="v4-editorial-actions">
              <a class="concept-button primary" href="#contact">Book appointment</a>
              <a class="concept-button secondary" href="#services">Explore services</a>
            </div>
          </div>
        </section>
      </header>

      <section class="tone-strip" aria-label="Brand focus">
        <span>Valencia Health & Wellness</span>
        <p>Personalized fitness, health evaluations, and virtual wellness coaching in Coconut Creek and beyond.</p>
        <a href="#contact">Start</a>
      </section>

      <section class="v4-welcome" aria-labelledby="welcome-title">
        <div class="v4-welcome-copy">
          <p class="concept-eyebrow">Welcome</p>
          <h2 id="welcome-title">Personalized fitness and wellness, cultivated around your goals.</h2>
          <p>
            Welcome to Valencia Health and Wellness, LLC, your premier destination for personalized fitness and wellness in Coconut Creek, Florida, and virtually via programming cultivated and curated to bring success to your dreams and goals.
          </p>
          <p>
            Whether you're looking to get fit, manage stress, or enhance your overall well-being, we have solutions tailored to your needs.
          </p>
        </div>
        <div class="v4-benefits" aria-label="Key benefits">
          <p class="concept-eyebrow">Key benefits</p>
          {benefits.map((benefit) => (
            <article>
              <h3>{benefit.title}</h3>
              <p>{benefit.text}</p>
            </article>
          ))}
        </div>
      </section>

      <section id="services" class="concept-services">
        <div class="concept-section-heading">
          <p class="concept-eyebrow">Programming sets</p>
          <h2>Specific programs for different bodies, goals, seasons, and levels of support.</h2>
        </div>
        <div class="v4-program-grid">
          {programs.map((program, index) => (
            <article>
              <span>{String(index + 1).padStart(2, "0")}</span>
              <h3>{program.title}</h3>
              <p>{program.text}</p>
            </article>
          ))}
        </div>
      </section>

      <section id="doctor" class="concept-doctor">
        <img src={withBase("/assets/brand/bruce-headshot.webp")} alt="Dr. Bruce Valencia" />
        <div>
          <p class="concept-eyebrow">Dr. Bruce Valencia</p>
          <h2>The plan changes when your coach understands the body clinically.</h2>
          <p>
            Doctor of Physical Therapy and Certified Lymphedema Therapist, blending evaluation, training, and wellness strategy into practical coaching.
          </p>
        </div>
      </section>

      <section id="contact" class="concept-contact">
        <img src={withBase("/assets/brand/valencia-health-wellness-logo-display.png")} alt="Valencia Health & Wellness logo" />
        <div>
          <p class="concept-eyebrow">Private consultation</p>
          <h2>Start with a clearer picture of what your body needs next.</h2>
          <a class="concept-button primary" href="tel:19542996536">Call 954-299-6536</a>
        </div>
      </section>
    </main>
  </body>
</html>
