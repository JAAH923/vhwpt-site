---
const basePath = import.meta.env.BASE_URL.endsWith("/") ? import.meta.env.BASE_URL : `${import.meta.env.BASE_URL}/`;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <meta http-equiv="refresh" content={`0; url=${basePath}`} />
    <link rel="canonical" href={basePath} />
    <title>Redirecting | Valencia Health & Wellness</title>
  </head>
  <body>
    <p>The concept gallery has been deprecated. <a href={basePath}>Go to the primary site.</a></p>
  </body>
</html>
