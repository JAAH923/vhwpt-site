---
import { concepts } from "../../data/concepts";

export function getStaticPaths() {
  return concepts.map((concept) => ({
    params: { id: concept.id },
  }));
}

const basePath = import.meta.env.BASE_URL.endsWith("/") ? import.meta.env.BASE_URL : `${import.meta.env.BASE_URL}/`;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <meta http-equiv="refresh" content={`0; url=${basePath}`} />
    <link rel="canonical" href={basePath} />
    <title>Redirecting | Valencia Health & Wellness</title>
  </head>
  <body>
    <p>This design concept has been deprecated. <a href={basePath}>Go to the primary site.</a></p>
  </body>
</html>
